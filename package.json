{
  "name": "forgewright",
  "version": "8.7.0",
  "description": "Adaptive AI Orchestrator — 52 skills, 19 modes. SaaS, game dev, XR, AI/ML, data engineering. Pipeline: DEFINE → BUILD → HARDEN → SHIP → SUSTAIN → GROW",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "build": "cd mcp && npm run build",
    "test": "cd mcp && npm run test",
    "lint": "cd mcp && npm run lint",
    "build:cli": "cd src/cli && npm install && npm run build",
    "dev:cli": "cd src/cli && npm run dev",
    "typecheck:cli": "cd src/cli && npx tsc --noEmit"
  },
  "devDependencies": {
    "@midscene/android": "^1.10.2",
    "@midscene/ios": "^1.10.2",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "handlebars": "^4.7.8",
    "husky": "^9.1.7",
    "js-yaml": "^4.2.0",
    "lint-staged": "^15.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "webdriverio": "^9.29.1"
  },
  "dependencies": {
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "mcp/src/**/*.ts": [
      "npx --prefix mcp eslint --fix --cache --cache-location mcp/node_modules/.cache/eslint",
      "npx --prefix mcp prettier --write"
    ],
    "src/cli/**/*.ts": [
      "npx --prefix mcp prettier --write"
    ],
    "**/*.py": [
      "ruff check --fix",
      "ruff format"
    ],
    "scripts/**/*.sh": [
      "bash -n"
    ]
  }
}
