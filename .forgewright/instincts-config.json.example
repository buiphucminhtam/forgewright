{
  "$schema": "https://raw.githubusercontent.com/buiphucminhtam/forgewright/main/.forgewright/instincts/instincts-config.schema.json",
  "_comment": "Per-project instinct system configuration. Copy to .forgewright/instincts-config.json in your project.",
  
  "enabled": true,
  "minSequenceLength": 3,
  "sequenceWindowSize": 10,
  "minInitialConfidence": 0.35,
  "promotionThreshold": 0.7,
  "maxEventsPerMinute": 60,
  "storePath": ".forgewright/instincts/store.json",
  "maxPatterns": 1000,
  "pruneThreshold": 0.15,
  "logLevel": "info",
  "autoSuggest": true,
  "maxSuggestionsPerSession": 3,
  "suggestionDebounceMs": 5000,
  "crossProjectTracking": true,
  "hashArguments": true
}
