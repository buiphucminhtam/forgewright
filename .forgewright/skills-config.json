{
  "$schema": "https://forgewright.dev/schemas/skills-config.json",
  "version": "1.0.0",
  "description": "Progressive Skill Loading — only load skills relevant to the classified mode. Inspired by DeerFlow 2.0 adaptive skill discovery. NOTE: These settings can also be defined in .production-grade.yaml under the 'skills:' key. YAML takes precedence if both exist.",

  "auto_detect": true,
  "auto_detect_rules": {
    "description": "When auto_detect is true, skills are loaded based on the classified mode. Manual overrides below take precedence.",
    "mode_skill_map": {
      "full-build": ["product-manager", "solution-architect", "software-engineer", "frontend-engineer", "qa-engineer", "security-engineer", "code-reviewer", "devops", "sre", "technical-writer"],
      "feature": ["product-manager", "solution-architect", "software-engineer", "frontend-engineer", "qa-engineer"],
      "harden": ["qa-engineer", "security-engineer", "code-reviewer", "performance-engineer"],
      "ship": ["devops", "sre"],
      "test": ["qa-engineer"],
      "review": ["code-reviewer"],
      "architect": ["solution-architect"],
      "document": ["technical-writer"],
      "explore": ["polymath"],
      "research": ["polymath"],
      "optimize": ["performance-engineer", "sre"],
      "design": ["ux-researcher", "ui-designer"],
      "mobile": ["mobile-engineer", "product-manager", "solution-architect"],
      "mobile-test": ["mobile-tester"],
      "marketing": ["growth-marketer", "conversion-optimizer"],
      "grow": ["conversion-optimizer", "growth-marketer"],
      "game-build": ["game-designer", "unity-engineer", "unreal-engineer", "godot-engineer", "roblox-engineer", "level-designer", "narrative-designer", "technical-artist", "game-asset-vfx", "game-audio-engineer"],
      "xr-build": ["xr-engineer", "game-designer"],
      "ai-build": ["ai-engineer", "prompt-engineer", "data-scientist", "web-scraper", "llm-tester"],
      "analyze": ["business-analyst"]
    }
  },

  "skills": {
    "_comment": "Manual overrides. Set enabled:false to force-disable a skill even if auto_detect would load it. Set enabled:true to force-load a skill regardless of mode.",

    "product-manager":        { "enabled": "auto" },
    "solution-architect":     { "enabled": "auto" },
    "software-engineer":      { "enabled": "auto" },
    "frontend-engineer":      { "enabled": "auto" },
    "qa-engineer":            { "enabled": "auto" },
    "security-engineer":      { "enabled": "auto" },
    "code-reviewer":          { "enabled": "auto" },
    "devops":                 { "enabled": "auto" },
    "sre":                    { "enabled": "auto" },
    "technical-writer":       { "enabled": "auto" },
    "ui-designer":            { "enabled": "auto" },
    "mobile-engineer":        { "enabled": "auto" },
    "mobile-tester":          { "enabled": "auto" },
    "api-designer":           { "enabled": "auto" },
    "database-engineer":      { "enabled": "auto" },
    "debugger":               { "enabled": "auto" },
    "prompt-engineer":        { "enabled": "auto" },
    "ai-engineer":            { "enabled": "auto" },
    "accessibility-engineer": { "enabled": "auto" },
    "performance-engineer":   { "enabled": "auto" },
    "ux-researcher":          { "enabled": "auto" },
    "data-engineer":          { "enabled": "auto" },
    "data-scientist":         { "enabled": "auto" },
    "xlsx-engineer":          { "enabled": "auto" },
    "project-manager":        { "enabled": "auto" },
    "business-analyst":       { "enabled": "auto" },
    "growth-marketer":        { "enabled": "auto" },
    "conversion-optimizer":   { "enabled": "auto" },
    "web-scraper":            { "enabled": "auto" },
    "polymath":               { "enabled": "auto" },

    "game-designer":          { "enabled": "auto" },
    "unity-engineer":         { "enabled": "auto" },
    "unreal-engineer":        { "enabled": "auto" },
    "godot-engineer":         { "enabled": "auto" },
    "godot-multiplayer":      { "enabled": "auto" },
    "roblox-engineer":        { "enabled": "auto" },
    "level-designer":         { "enabled": "auto" },
    "narrative-designer":     { "enabled": "auto" },
    "technical-artist":       { "enabled": "auto" },
    "game-asset-vfx":         { "enabled": "auto" },
    "game-audio-engineer":    { "enabled": "auto" },
    "unity-shader-artist":    { "enabled": "auto" },
    "unity-multiplayer":      { "enabled": "auto" },
    "unreal-technical-artist":{ "enabled": "auto" },
    "unreal-multiplayer":     { "enabled": "auto" },
    "xr-engineer":            { "enabled": "auto" },

    "parallel-dispatch":      { "enabled": "auto" },
    "memory-manager":         { "enabled": "auto" },
    "skill-maker":            { "enabled": "auto" },
    "mcp-generator":          { "enabled": "auto" },
    "llm-tester":             { "enabled": "auto" }
  },

  "context_budget": {
    "max_skill_descriptions_tokens": 8000,
    "max_skills_per_mode": 12,
    "fallback_on_classification_failure": "load_all"
  }
}
