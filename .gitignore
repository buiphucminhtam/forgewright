# ─── Global ────────────────────────────────────────────────────────────────

# Memory / embedding caches
.forge17/
.embeddings/
.forgenexus/
.gitnexus/

# Node modules (all of them)
node_modules/

# Antigravity CLI local project config
.antigravitycli/

# ForgeNexus / legacy auto-generated Claude Code files — Antigravity uses its own protocols
.claude/

# Build output
build/
!mcp/build/
dist/
*.js.map

# Python cache
__pycache__/
*.pyc
*.pyo

# Antigravity plugin internals (nested git submodule, caches, local MCP server)
.antigravity/.git/
.antigravity/.forgenexus/
.antigravity/.gitnexus/
.antigravity/.forgewright/
.antigravity/.forge17/
.antigravity/.memignore

# Husky internals (generated by `husky install`)
.husky/_/

# Antigravity planning directories (ephemeral planning notes)
antigravity/planning/

# Local sensitive configuration and credentials
.tieu-mo-config.md
scripts/cf-dns-add.sh
scripts/cf-dns-remove.sh
.next/

# Excel/spreadsheet files (may contain sensitive data)
*.xlsx
*.xls

