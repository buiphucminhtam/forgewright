#!/bin/sh
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Pre-commit Hook — Parallel Execution v3.0 (TS & Python)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

. "$(dirname "$0")/_/husky.sh"

echo "Running pre-commit checks..."

# ── Wave 0: Documentation Consistency & Drift check ───────────────────────
echo "[0/4] Running Wiki Drift & Conflict checks..."
bash scripts/verify-wiki-drift.sh --threshold 0.3
if [ $? -ne 0 ]; then
  echo "Wiki Drift or Contradiction check failed! Commit blocked."
  exit 1
fi

# ── Wave 0.5: Conditional GitNexus & Sequence Diagram Update ─────────────
echo "[0.5/4] Checking for logic changes to update sequence diagrams & index..."
LOGIC_CHANGES=$(git diff --cached --name-only | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|py|go|rs|cs|gd|c|cpp|h|hpp|cc|java|kt|swift)$' | grep -v -E '(test|__tests__|jest|vitest|playwright|config)' || true)

if [ -n "$LOGIC_CHANGES" ]; then
  echo "⚙️ [Forgewright] Logic changes detected in staged files. Updating index and flow charts..."
  
  # 1. Run gitnexus analyze
  gitnexus analyze || echo "⚠️ GitNexus analyze failed, skipping index update."
  
  # 2. Update sequence diagrams
  npx tsx scripts/generate-sequence.ts || echo "⚠️ Sequence diagram generation failed, skipping diagram update."
  
  # 3. Stage updated files
  git add docs/architecture/flows/ || true
fi

# ── Wave 1: Linting & Formatting via lint-staged ──────────────────────────
echo "[1/4] Running lint-staged..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "lint-staged failed! Commit blocked."
  exit 1
fi

# ── Wave 2: TypeScript check ──────────────────────────────────────────────
echo "[2/4] Running TypeScript check (mcp)..."
cd mcp && npx tsc --noEmit
TYPE_MCP_RC=$?
cd ..

if [ $TYPE_MCP_RC -ne 0 ]; then
  echo "TypeScript check failed! Commit blocked."
  exit 1
fi

# ── Wave 3: Unit Tests (Vitest & pytest in parallel) ─────────────────────
(
  echo "[4/4] Running Vitest (TS)..."
  cd mcp && npx vitest run --reporter=basic
  vitest_rc=$?
  exit $vitest_rc
) &
VITEST_PID=$!

(
  echo "[4/4] Running Pytest (Python)..."
  pytest tests/unit_tests/
  pytest_rc=$?
  exit $pytest_rc
) &
PYTEST_PID=$!

# Wait for Wave 3
wait $VITEST_PID
vitest_rc=$?
wait $PYTEST_PID
pytest_rc=$?

if [ $vitest_rc -ne 0 ]; then
  echo "Vitest failed! Commit blocked."
  exit 1
fi

if [ $pytest_rc -ne 0 ]; then
  echo "Pytest failed! Commit blocked."
  exit 1
fi

echo "All pre-commit checks passed!"
exit 0
