#!/bin/sh
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Pre-commit Hook — Parallel Execution v2.0
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

. "$(dirname "$0")/_/husky.sh"

echo "Running pre-commit checks..."

# ── Wave 0: Documentation Consistency & Drift check ───────────────────────
echo "[0/4] Running Wiki Drift & Conflict checks..."
bash scripts/verify-wiki-drift.sh --threshold 0.3
if [ $? -ne 0 ]; then
  echo "Wiki Drift or Contradiction check failed! Commit blocked."
  exit 1
fi

cd mcp

# ── Wave 1: Linting & Formatting (independent — parallel) ─────────────────
(
  echo "[1/2] Running ESLint (cached)..."
  npx eslint src/ --max-warnings=0 --cache --cache-location node_modules/.cache/eslint
  ESLINT_RC=$?
  if [ $ESLINT_RC -ne 0 ]; then
    echo "[ESLint] FAILED"
  fi
  exit $ESLINT_RC
) &
ESLINT_PID=$!

(
  echo "[2/2] Running Prettier check..."
  npx prettier --check "src/**/*.ts"
  PRETTY_RC=$?
  if [ $PRETTY_RC -ne 0 ]; then
    echo "[Prettier] FAILED"
  fi
  exit $PRETTY_RC
) &
PRETTY_PID=$!

# Wait for wave 1
wait $ESLINT_PID
ESLINT_RC=$?
wait $PRETTY_PID
PRETTY_RC=$?

if [ $ESLINT_RC -ne 0 ]; then
  echo "ESLint failed!"
  exit 1
fi

if [ $PRETTY_RC -ne 0 ]; then
  echo "Prettier check failed!"
  exit 1
fi

# ── Wave 2: TypeScript & Tests (parallel — Vitest doesn't need tsc output) ──
(
  echo "[3/4] Running TypeScript check..."
  npx tsc --noEmit
  TYPE_RC=$?
  if [ $TYPE_RC -ne 0 ]; then
    echo "[TypeScript] FAILED"
  fi
  exit $TYPE_RC
) &
TYPE_PID=$!

(
  echo "[4/4] Running tests..."
  npx vitest run --reporter=basic
  TEST_RC=$?
  if [ $TEST_RC -ne 0 ]; then
    echo "[Tests] FAILED"
  fi
  exit $TEST_RC
) &
TEST_PID=$!

# Wait for wave 2
wait $TYPE_PID
TYPE_RC=$?
wait $TEST_PID
TEST_RC=$?

if [ $TYPE_RC -ne 0 ]; then
  echo "TypeScript check failed!"
  exit 1
fi

if [ $TEST_RC -ne 0 ]; then
  echo "Tests failed!"
  exit 1
fi

echo "All pre-commit checks passed!"
exit 0
